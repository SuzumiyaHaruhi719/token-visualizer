{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Monitor",
  "version": "0.1.0",
  "identifier": "com.thomas.claudemonitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5847",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../dist": "dist",
      "assets/session-end.wav": "assets/session-end.wav"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
